{
  "name": "@oversync/relayer",
  "version": "1.0.0",
  "description": "Event relayer service that listens to Ethereum events and triggers Stellar operations",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^11.3.0",
    "@types/node": "^22.10.0",
    "axios": "^1.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "typescript": "^5.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "tsx": "^4.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "relayer",
    "ethereum",
    "stellar",
    "event-listener",
    "cross-chain"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}